{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "outDir": "./dist/server",
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "types": ["node"]
  },
  "include": [
    "server.ts",
    "server/**/*.ts",
    "src/types/index.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "src/**/*.tsx"
  ]
}
