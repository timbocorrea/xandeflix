{
  "functions": {
    "api/[...path].ts": {
      "includeFiles": "{server.ts,server/**,src/types/**,users.json,.env.example}"
    }
  },
  "routes": [
    { "src": "^/api/(.*)$", "dest": "/api/[...path].ts" },
    { "handle": "filesystem" },
    { "src": "^(?!/api).*$", "dest": "/index.html" }
  ]
}
